ARG BASE_IMAGE=empiria-claude:latest
FROM ${BASE_IMAGE}
USER root

# Playwright system dependencies for browser testing
RUN npx playwright install-deps chromium

USER scion

# Playwright browser + pytest integration
# Use full venv path — parent ENV may not propagate in all build contexts
RUN /home/scion/.venv/bin/pip install pytest-playwright && \
    /home/scion/.venv/bin/playwright install chromium
