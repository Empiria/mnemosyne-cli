ARG BASE_IMAGE=empiria-claude:latest
FROM ${BASE_IMAGE}
USER root

# Playwright system dependencies for browser testing
RUN npx playwright install-deps chromium

USER scion

# Playwright browser + pytest integration
# uv venv doesn't include pip — use uv pip to install into the venv
ENV PATH="/home/scion/.local/bin:/home/scion/.venv/bin:$PATH"
RUN uv pip install pytest-playwright && \
    playwright install chromium

# Run as root so sciontool init can fix volume ownership before dropping privileges
USER root
